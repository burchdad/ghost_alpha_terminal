# Public browser-side API base.
# Leave unset in Vercel to use same-origin /api proxy route.
NEXT_PUBLIC_API_BASE=

# Server-side backend origin used by Next.js API proxy route.
# In Vercel, set this to your Railway backend URL.
# Example: https://ghost-alpha-terminal-backend.up.railway.app
BACKEND_URL=http://localhost:8000
