# ─────────────────────────────────────────────────────────────────────────────
# Ghost Alpha Terminal — Backend Environment Variables
#
# Copy this file to .env for local development.
# For Railway production, set these directly in the service's Variables tab.
# NEVER commit a filled-in .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production                        # dev | staging | production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Railway injects the frontend URL here — no trailing slash.
# Example: https://ghost-alpha-frontend.up.railway.app
# Use * only for local development.
ALLOWED_ORIGINS=https://your-frontend.up.railway.app

# ── Database ─────────────────────────────────────────────────────────────────
# Railway provisions Postgres and auto-sets DATABASE_URL.
# Local fallback: leave empty and SQLite is used.
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# ── Alpaca ───────────────────────────────────────────────────────────────────
# Paper trading keys from https://app.alpaca.markets/ (paper dashboard)
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
ALPACA_PAPER=true    # true = paper endpoint | false = live capital (use with extreme care)

# Alpaca Connect (OAuth app) credentials from https://app.alpaca.markets/connect
# Keep these secret; never commit real values.
ALPACA_CONNECT_CLIENT_ID=your_alpaca_connect_client_id_here
ALPACA_CONNECT_CLIENT_SECRET=your_alpaca_connect_client_secret_here
ALPACA_CONNECT_REDIRECT_URI=https://your-domain.com/api/auth/alpaca/callback
# Optional override endpoints (defaults are already correct for Alpaca Connect)
ALPACA_CONNECT_AUTHORIZE_URL=https://app.alpaca.markets/oauth/authorize
ALPACA_CONNECT_TOKEN_URL=https://api.alpaca.markets/oauth/token

# ── Coinbase Advanced Trade (API key mode) ───────────────────────────────────
# API key name and private key PEM generated in Coinbase Developer Platform.
# Keep both secret; never commit real values.
COINBASE_API_KEY_NAME=organizations/your-org-id/apiKeys/your-key-id
COINBASE_API_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"

# ── Redis / Celery (optional) ─────────────────────────────────────────────────
# Only needed if background task queue is active.
# Railway can provision Redis as an add-on service.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Misc ─────────────────────────────────────────────────────────────────────
USE_MOCK_DATA=false       # Keep false in production for live market inputs
