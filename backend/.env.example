# ─────────────────────────────────────────────────────────────────────────────
# Ghost Alpha Terminal — Backend Environment Variables
#
# Copy this file to .env for local development.
# For deployed environments, set these directly in your platform's Variables tab.
# NEVER commit a filled-in .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production                        # dev | staging | production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example: https://ghost-alpha-frontend.vercel.app
# Use * only for local development.
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ── Database ─────────────────────────────────────────────────────────────────
# Neon Postgres URL (recommended early-stage path).
# Use the pooled connection string from Neon dashboard and keep sslmode=require.
# Local fallback: leave empty and SQLite is used.
DATABASE_URL=postgresql+psycopg://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Auth / Session ───────────────────────────────────────────────────────────
# Generate a long random secret: openssl rand -hex 64
AUTH_SESSION_SECRET=replace_with_64_plus_char_random_secret
# false for local HTTP dev, true for HTTPS deployments
AUTH_COOKIE_SECURE=false
# lax is usually the best default for app login redirects
AUTH_COOKIE_SAMESITE=lax
# Frontend origin used after OAuth callback success
FRONTEND_BASE_URL=http://localhost:3000

# ── Alpaca ───────────────────────────────────────────────────────────────────
# Paper trading keys from https://app.alpaca.markets/ (paper dashboard)
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
ALPACA_PAPER=true    # true = paper endpoint | false = live capital (use with extreme care)

# Alpaca Connect (OAuth app) credentials from https://app.alpaca.markets/connect
# Keep these secret; never commit real values.
ALPACA_CONNECT_CLIENT_ID=your_alpaca_connect_client_id_here
ALPACA_CONNECT_CLIENT_SECRET=your_alpaca_connect_client_secret_here
ALPACA_CONNECT_REDIRECT_URI=https://your-backend-domain.com/auth/alpaca/callback
# Optional override endpoints (defaults are already correct for Alpaca Connect)
ALPACA_CONNECT_AUTHORIZE_URL=https://app.alpaca.markets/oauth/authorize
ALPACA_CONNECT_TOKEN_URL=https://api.alpaca.markets/oauth/token

# ── Coinbase Advanced Trade (API key mode) ───────────────────────────────────
# API key name and private key PEM generated in Coinbase Developer Platform.
# Keep both secret; never commit real values.
COINBASE_API_KEY_NAME=organizations/your-org-id/apiKeys/your-key-id
COINBASE_API_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"
COINBASE_LIVE_TRADING_ENABLED=true
COINBASE_TRADE_PRODUCTS=BTC-USD,ETH-USD,SOL-USD
COINBASE_WS_ENABLED=true
COINBASE_WS_PRODUCTS=BTC-USD,ETH-USD,SOL-USD
COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com

# ── Tradier (API key mode, sandbox/live) ─────────────────────────────────────
# Sandbox base: https://sandbox.tradier.com/v1
# Live base:    https://api.tradier.com/v1
TRADIER_SANDBOX_API_KEY=your_tradier_sandbox_api_key_here
TRADIER_SANDBOX_ACCOUNT_NUMBER=your_tradier_sandbox_account_number_here
TRADIER_LIVE_API_KEY=your_tradier_live_api_key_here
TRADIER_LIVE_ACCOUNT_NUMBER=your_tradier_live_account_number_here
TRADIER_SANDBOX=true
TRADIER_LIVE_TRADING_ENABLED=true
# Optional explicit API host override (leave blank for default sandbox/live host)
TRADIER_BASE_URL=
# Legacy fallback vars (optional):
# TRADIER_API_KEY=
# TRADIER_ACCOUNT_NUMBER=

# ── Redis / Celery (optional) ─────────────────────────────────────────────────
# Only needed if background task queue is active.
# Railway can provision Redis as an add-on service.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Misc ─────────────────────────────────────────────────────────────────────
USE_MOCK_DATA=false       # Keep false in production for live market inputs
